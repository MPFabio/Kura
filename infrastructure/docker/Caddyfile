{$KURA_DOMAIN} {
    tls {$ACME_EMAIL}
    encode gzip

    # Routes API → Kong
    handle /api/* {
        reverse_proxy kong:8000
    }

    # Webhooks → Kong
    handle /webhooks/* {
        reverse_proxy kong:8000
    }

    # Tout le reste → Frontend (nginx)
    handle {
        reverse_proxy frontend:80
    }

    log {
        output stderr
        level INFO
    }
}
