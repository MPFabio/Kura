{$KURA_DOMAIN} {
    tls {$ACME_EMAIL}
    encode gzip

    # Dashboard Grafana exposé via sous-chemin /grafana
    handle /grafana/* {
        uri strip_prefix /grafana
        reverse_proxy grafana:3000
    }

    # Routes API → Kong
    handle /api/* {
        reverse_proxy kong:8000
    }

    # Webhooks → Kong
    handle /webhooks/* {
        reverse_proxy kong:8000
    }

    # Tout le reste → Frontend (nginx)
    handle {
        reverse_proxy frontend:80
    }

    log {
        output stderr
        level INFO
    }
}
