{
  "dashboard": {
    "title": "Ansible Service - Métriques",
    "tags": ["ansible", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Requêtes API par seconde",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(ansible_api_requests_total[1m])",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requêtes/seconde"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Statut des requêtes API",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum by (status) (ansible_api_requests_total)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Durée des requêtes API (p95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ansible_api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 - {{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Durée (secondes)"},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "title": "Jobs lancés",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(ansible_jobs_launched_total[5m])",
            "legendFormat": "Template {{template_id}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Jobs/seconde"},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "Requêtes vers Ansible Tower",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "rate(ansible_tower_api_requests_total[1m])",
            "legendFormat": "{{method}} {{endpoint}} - {{status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requêtes/seconde"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "Webhooks reçus",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(ansible_webhooks_received_total[1m])",
            "legendFormat": "{{event_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Webhooks/seconde"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "Connexions WebSocket actives",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "ansible_active_websocket_connections",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          }
        }
      },
      {
        "id": 8,
        "title": "Cache Hits/Misses",
        "type": "graph",
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 24},
        "targets": [
          {
            "expr": "rate(ansible_cache_hits_total[1m])",
            "legendFormat": "Hits - {{cache_type}}",
            "refId": "A"
          },
          {
            "expr": "rate(ansible_cache_misses_total[1m])",
            "legendFormat": "Misses - {{cache_type}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Opérations/seconde"},
          {"format": "short"}
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    }
  }
}
