# =============================================================================
# KURA — Variables d'environnement (template)
# Copier ce fichier en .env et remplir toutes les valeurs CHANGE_ME avant de
# lancer docker compose. Ne jamais committer .env dans git.
# =============================================================================

# PostgreSQL
POSTGRES_DB=kura
POSTGRES_USER=kura
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis — le mot de passe est requis (--requirepass activé)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=kura-services

# Kong
KONG_ADMIN_URL=http://kong:8001
KONG_PROXY_URL=http://kong:8000

# Prometheus
PROMETHEUS_URL=http://prometheus:9090

# Grafana — GF_SECURITY_ADMIN_PASSWORD est utilisé par le conteneur Grafana
GRAFANA_URL=http://grafana:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# JWT — Générer avec : openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRATION=24h

# Terraform — doit faire exactement 32 octets
TERRAFORM_ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_BYTES_KEY!!

# Webhook — secret partagé pour valider les signatures HMAC-SHA256 GitHub/GitLab
# Générer avec : openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# URLs inter-services
AUTH_SERVICE_URL=http://auth-service:8080
K8S_SERVICE_URL=http://k8s-service:8081
TERRAFORM_SERVICE_URL=http://terraform-service:8082
ANSIBLE_SERVICE_URL=http://ansible-service:8083
PIPELINE_SERVICE_URL=http://pipeline-service:8084
ALERT_SERVICE_URL=http://alert-service:8085
METRICS_SERVICE_URL=http://metrics-service:8086

# Contournements Kong (502 / Empty reply) — à définir avant le build du frontend
# VITE_AUTH_URL=http://localhost:8080
# VITE_PIPELINE_URL=http://localhost:8084

# Kubernetes
KUBECONFIG_PATH=~/.kube/config

# GCP — pour GKE : copier la clé JSON dans secrets/gcp-sa.json (jamais committé)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
GCP_SA_KEY_PATH=./secrets/gcp-sa.json

# Terraform Cloud (optionnel)
TERRAFORM_CLOUD_TOKEN=
TERRAFORM_CLOUD_ORG=

# Backend tfstate S3/MinIO (optionnel — profil tfstate)
TERRAFORM_STATE_BACKEND=
AWS_S3_BUCKET=kura-tfstate
AWS_S3_REGION=us-east-1
AWS_S3_KEY_PREFIX=tfstate
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MinIO (optionnel)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# Ansible Tower / AWX
ANSIBLE_TOWER_URL=http://host.docker.internal:8052
ANSIBLE_TOWER_USERNAME=admin
ANSIBLE_TOWER_PASSWORD=CHANGE_ME_AWX_PASSWORD

# GitHub — générer sur https://github.com/settings/tokens (scope: repo, workflow)
GITHUB_TOKEN=CHANGE_ME_GITHUB_PAT
GITHUB_REPOS=owner/repo1,owner/repo2

# GitLab (optionnel)
GITLAB_TOKEN=

# Jenkins (optionnel)
JENKINS_URL=
JENKINS_USERNAME=
JENKINS_TOKEN=

# Application
ENV=development
LOG_LEVEL=info
