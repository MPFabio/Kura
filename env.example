# Configuration PostgreSQL
POSTGRES_DB=kura
POSTGRES_USER=kura
POSTGRES_PASSWORD=kura
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Configuration Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Configuration Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=kura-services

# Configuration Kong
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000

# Configuration Prometheus
PROMETHEUS_URL=http://localhost:9090

# Configuration Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Configuration JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# Configuration des services
AUTH_SERVICE_URL=http://localhost:8080
K8S_SERVICE_URL=http://localhost:8081
TERRAFORM_SERVICE_URL=http://localhost:8082
ANSIBLE_SERVICE_URL=http://localhost:8083
PIPELINE_SERVICE_URL=http://localhost:8084

# Contournements Kong (502 / Empty reply) - à définir avant le build du frontend
# Si la page de login affiche souvent des 502, définir VITE_AUTH_URL pour appeler auth-service directement :
# VITE_AUTH_URL=http://localhost:8080
# VITE_PIPELINE_URL=http://localhost:8084
ALERT_SERVICE_URL=http://localhost:8085
METRICS_SERVICE_URL=http://localhost:8086

# Configuration Kubernetes
KUBECONFIG_PATH=~/.kube/config

# GKE (cluster GCP) : pour que le k8s-service utilise le kubeconfig gcloud, définir et monter la clé SA
# Copier la clé JSON du compte de service dans secrets/gcp-sa.json (voir docs/CONNECTER_CLUSTER_GKE.md)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
# GCP_SA_KEY_PATH=./secrets/gcp-sa.json

# Configuration Terraform
TERRAFORM_CLOUD_TOKEN=
TERRAFORM_CLOUD_ORG=

# Backend tfstate (S3 / MinIO) : persistance des états dans un bucket
# Si TERRAFORM_STATE_BACKEND=s3, chaque état uploadé est aussi enregistré dans le bucket.
# Avec MinIO : docker compose --profile tfstate up puis définir :
TERRAFORM_STATE_BACKEND=
AWS_S3_BUCKET=kura-tfstate
AWS_S3_REGION=us-east-1
AWS_S3_KEY_PREFIX=tfstate
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Configuration Ansible Tower / AWX (pour le module Ansible)
# Dev local : AWX sur la machine hôte. Prod : utilisez des identifiants sécurisés.
ANSIBLE_TOWER_URL=http://host.docker.internal:8052
ANSIBLE_TOWER_USERNAME=admin
ANSIBLE_TOWER_PASSWORD=changeme

# Configuration CI/CD
# Lier GitHub Actions au module Pipeline (sync par API - pas de webhook) :
GITHUB_TOKEN=
GITHUB_REPOS=owner/repo
# ex: GITHUB_REPOS=modulops/ModulOps ou user/repo1,user/repo2
GITLAB_TOKEN=
JENKINS_URL=
JENKINS_USERNAME=
JENKINS_TOKEN=

# Environnement
ENV=development
LOG_LEVEL=info
